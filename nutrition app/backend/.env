# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/multifit

# Auth
JWT_SECRET= Life-Is-Not-To-Be-Taken-For-Granted
JWT_EXPIRES_IN=30d

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=multifit-media

# Expo Push Notifications
# (no secret needed — uses Expo's public push service)
